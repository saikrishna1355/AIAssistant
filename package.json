{
  "name": "interview-copilot-ai",
  "version": "1.0.0",
  "description": "Desktop AI Interview and Coding Copilot",
  "main": "src/main.js",
  "scripts": {
    "start": "node src/server.js",
    "electron": "electron src/main.js",
    "dev": "nodemon src/main.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.interview-copilot-ai",
    "productName": "Interview Copilot AI",
    "files": ["src/**/*", "public/**/*"],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "snap"]
    }
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.454.0",
    "@aws-sdk/client-transcribe": "^3.454.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1063.0",
    "aws-sdk": "^2.1491.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-record-lpcm16": "^1.0.1",
    "screenshot-desktop": "^1.15.0",
    "socket.io": "^4.7.4",
    "tesseract.js": "^4.1.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "author": "Interview Copilot AI Team",
  "license": "MIT"
}

